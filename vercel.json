{
  "buildCommand": "node build.js",
  "outputDirectory": "dist",
  "installCommand": "",
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/about",        "destination": "/static/about" },
    { "source": "/scorecard",    "destination": "/static/scorecard" },
    { "source": "/disclaimer",   "destination": "/static/disclaimer" },
    { "source": "/legal-notice", "destination": "/static/legal-notice" },
    { "source": "/robots.txt",   "destination": "/static/robots.txt" },
    { "source": "/sitemap.xml",  "destination": "/static/sitemap.xml" }
  ],
  "redirects": [
    { "source": "/analyses/spy-ipo-fork-747", "destination": "/analyses/spy-747-level", "permanent": true },
    { "source": "/analyses/images/spy-ipo-fork-chart-202605.jpg", "destination": "/analyses/images/spy-747-chart-202605.jpg", "permanent": true }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options",    "value": "nosniff" },
        { "key": "X-Frame-Options",            "value": "DENY" },
        { "key": "Referrer-Policy",            "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy",         "value": "camera=(), microphone=(), geolocation=()" },
        { "key": "Content-Security-Policy",    "value": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https:; connect-src 'self' https://yahoo-proxy.marccharnal.workers.dev" }
      ]
    }
  ]
}
